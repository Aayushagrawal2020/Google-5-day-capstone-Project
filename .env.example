# MockMentor Environment Variables Configuration
# Copy this file to .env and replace the placeholder with your actual API key.

# Your Gemini API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=

# Mode configurations: set to False to run the real ADK 2.0 Workflow Agent
# (Fallback to MockMode automatically happens if GEMINI_API_KEY is not set)
MOCK_MODE=False
